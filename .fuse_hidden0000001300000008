<script>
(function(){
  // Shim parseFloat so every existing call site transparently tolerates
  // comma-grouped input ("100,000") without needing to touch each call site.
  function parseFloat(v) { return window.parseFloat(String(v).replace(/,/g, '')); }

  const AMBER = '#C9A45C';
  const SLATE = '#5B7A9D';
  const COPPER = '#B07A4E';
  const SEAM = '#24344A';
  const PARCHMENT_FAINT = '#948D79';

  const LIMITS = {
    initial: { min: 100, max: 10000000 },
    yield: { min: 0.1, max: 15 },
    divGrowth: { min: 0, max: 20 },
    pxGrowth: { min: -5, max: 15 },
    years: { min: 1, max: 50 }
  };

  let chart = null;
  let incomeChart = null;

  function fmt(n) {
    const sign = n < 0 ? '-' : '';
    return sign + '$' + Math.round(Math.abs(n)).toLocaleString();
  }
  // Same as fmt() but without the leading $ — used to redisplay money input
  // fields themselves with thousands separators after the user leaves them.
  function formatMoneyValue(n) {
    if (isNaN(n)) return '';
    const sign = n < 0 ? '-' : '';
    return sign + Math.round(Math.abs(n)).toLocaleString();
  }
  function fmtShort(n) {
    const a = Math.abs(n);
    if (a >= 1000000) return '$' + (n / 1000000).toFixed(2) + 'M';
    if (a >= 1000) return '$' + Math.round(n / 1000) + 'k';
    return '$' + Math.round(n);
  }
  function clamp(val, min, max) {
    if (isNaN(val)) return min;
    return Math.min(max, Math.max(min, val));
  }
  function markValidity(el, value, min, max) {
    const bad = isNaN(value) || value < min || value > max;
    el.classList.toggle('invalid', bad);
  }
  function getInputs() {
    return {
      initial: clamp(parseFloat(document.getElementById('initial').value), LIMITS.initial.min, LIMITS.initial.max),
      yield: clamp(parseFloat(document.getElementById('yield').value), LIMITS.yield.min, LIMITS.yield.max),
      divGrowth: clamp(parseFloat(document.getElementById('div-growth').value), LIMITS.divGrowth.min, LIMITS.divGrowth.max),
      pxGrowth: clamp(parseFloat(document.getElementById('px-growth').value), LIMITS.pxGrowth.min, LIMITS.pxGrowth.max),
      years: Math.round(clamp(parseFloat(document.getElementById('years').value), LIMITS.years.min, LIMITS.years.max)),
      reinvest: document.getElementById('reinvest').checked
    };
  }

  // --- Shareable link encode/decode (same pattern as the other Phases calculators) ---
  function encodeState() {
    const i = getInputs();
    const state = { i: i.initial, y: i.yield, d: i.divGrowth, p: i.pxGrowth, t: i.years, r: i.reinvest ? 1 : 0 };
    const json = JSON.stringify(state);
    const b64 = btoa(unescape(encodeURIComponent(json)));
    return b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  }
  function decodeState(encoded) {
    try {
      const b64 = encoded.replace(/-/g, '+').replace(/_/g, '/');
      const json = decodeURIComponent(escape(atob(b64)));
      const state = JSON.parse(json);
      if (!state || typeof state.i === 'undefined') return null;
      return state;
    } catch (e) { return null; }
  }
  function applyState(s) {
    document.getElementById('initial').value = formatMoneyValue(clamp(s.i, LIMITS.initial.min, LIMITS.initial.max));
    document.getElementById('yield').value = clamp(s.y, LIMITS.yield.min, LIMITS.yield.max);
    document.getElementById('div-growth').value = clamp(s.d, LIMITS.divGrowth.min, LIMITS.divGrowth.max);
    document.getElementById('px-growth').value = clamp(s.p, LIMITS.pxGrowth.min, LIMITS.pxGrowth.max);
    document.getElementById('years').value = clamp(s.t, LIMITS.years.min, LIMITS.years.max);
    document.getElementById('reinvest').checked = !!s.r;
  }
  function updateUrlSilently() {
    const url = new URL(window.location.href);
    url.searchParams.set('d', encodeState());
    window.history.replaceState(null, '', url.toString());
  }
  let urlUpdateTimer = null;
  function scheduleUrlUpdate() {
    clearTimeout(urlUpdateTimer);
    urlUpdateTimer = setTimeout(updateUrlSilently, 400);
  }

  function computeSeries() {
    const i = getInputs();
    const gd = i.divGrowth / 100;
    const gp = i.pxGrowth / 100;
    const p0 = 100;
    const s0 = i.initial / p0;
    const d0 = p0 * (i.yield / 100);   // dividend per share paid in year 1

    // Year t (1-based): dividend per share = d0*(1+gd)^(t-1), paid at year end;
    // price at year end = p0*(1+gp)^t; DRIP reinvests at the year-end price.
    let dripShares = s0;
    let cashCollected = 0;
    const series = [{ year: 0, drip: i.initial, cash: i.initial, dripIncome: 0, cashIncome: 0, shares: s0, cumCash: 0 }];

    for (let t = 1; t <= i.years; t++) {
      const dps = d0 * Math.pow(1 + gd, t - 1);
      const price = p0 * Math.pow(1 + gp, t);
      const dripIncome = dripShares * dps;
      const cashIncome = s0 * dps;
      dripShares += dripIncome / price;
      cashCollected += cashIncome;
      series.push({
        year: t,
        drip: dripShares * price,
        cash: s0 * price,
        dripIncome, cashIncome,
        shares: dripShares,
        cumCash: cashCollected
      });
    }

    const last = series[series.length - 1];
    return {
      inputs: i, series,
      dripValue: last.drip,
      cashValue: last.cash,
      cashCollected,
      finalDripIncome: last.dripIncome,
      finalCashIncome: last.cashIncome,
      finalShares: last.shares,
      startShares: s0,
      advantage: last.drip - (last.cash + cashCollected),
      yocDrip: (last.dripIncome / i.initial) * 100,
      yocCash: (last.cashIncome / i.initial) * 100
    };
  }

  function renderWarnings(r) {
    const el = document.getElementById('warnings');
    el.innerHTML = '';
    if (r.inputs.yield >= 8) {
      const div = document.createElement('div');
      div.className = 'warning';
      div.textContent = r.inputs.yield + '% yields are often a warning, not a gift — the market may be pricing in a dividend cut. Check the payout ratio before assuming this income is durable.';
      el.appendChild(div);
    }
    if (r.inputs.pxGrowth <= 0 && r.inputs.divGrowth >= 3 && r.inputs.years >= 10) {
      const div = document.createElement('div');
      div.className = 'warning';
      div.textContent = 'A price that falls or stalls for ' + r.inputs.years + ' years while the dividend keeps growing ' + r.inputs.divGrowth + '%/yr isn’t sustainable — real companies in that position cut the payout. Reinvesting at ever-cheaper prices makes the math look spectacular; treat this as an illustration, not a plan.';
      el.appendChild(div);
    }
    if (r.inputs.divGrowth >= 10 && r.inputs.years >= 20) {
      const div = document.createElement('div');
      div.className = 'info-note';
      div.textContent = r.inputs.divGrowth + '% dividend growth sustained for ' + r.inputs.years + ' years is rare — payouts can’t outgrow earnings forever. Treat this as an optimistic scenario.';
      el.appendChild(div);
    }
    if (!r.inputs.reinvest) {
      const div = document.createElement('div');
      div.className = 'info-note';
      div.textContent = 'Planning around taking the cash: over ' + r.inputs.years + ' years you’d collect ' + fmt(r.cashCollected) + ' in dividends, but end ' + fmt(r.advantage) + ' behind the reinvested path even counting every check.';
      el.appendChild(div);
    }
  }

  function renderAdvBar(r) {
    const bar = document.getElementById('adv-bar');
    const cap = document.getElementById('adv-caption');
    bar.innerHTML = '';

    const cashTotal = r.cashValue + r.cashCollected;
    const total = Math.max(r.dripValue, cashTotal, 1);
    const cashPct = Math.max(2, (cashTotal / total) * 100);
    const bonusPct = Math.max(2, 100 - cashPct);

    const c = document.createElement('div');
    c.className = 'adv-seg cashpath';
    c.style.flex = cashPct;
    c.textContent = 'cash path ' + fmtShort(r.cashValue) + ' + ' + fmtShort(r.cashCollected) + ' collected';
    bar.appendChild(c);

    if (r.advantage > 0.5) {
      const b = document.createElement('div');
      b.className = 'adv-seg bonus';
      b.style.flex = bonusPct;
      b.textContent = 'DRIP bonus ' + fmtShort(r.advantage);
      bar.appendChild(b);
    }

    cap.textContent = 'Even crediting every dividend check as saved cash, reinvesting ends ' + fmt(r.advantage) +
      ' ahead — pure compounding. Yield on cost after ' + r.inputs.years + ' years: ' + r.yocDrip.toFixed(1) + '% with DRIP, ' + r.yocCash.toFixed(1) + '% without.';
  }

  function renderSummaryTable(r) {
    const el = document.getElementById('summary-table');
    const marks = [];
    for (let y = 5; y < r.inputs.years; y += 5) marks.push(y);
    marks.push(r.inputs.years);

    let html = '<table><tr><th>Year</th><th>Shares (DRIP)</th><th>Value (DRIP)</th><th>Value (cash taken)</th><th>Income that year (DRIP)</th></tr>';
    marks.forEach(y => {
      const pt = r.series[y];
      if (!pt) return;
      html += '<tr><td>' + y + (y === r.inputs.years ? ' — end' : '') + '</td><td>' + pt.shares.toFixed(1) + '</td>' +
        '<td class="hi">' + fmt(pt.drip) + '</td><td>' + fmt(pt.cash) + '</td><td>' + fmt(pt.dripIncome) + '</td></tr>';
    });
    html += '</table>';
    el.innerHTML = html;

    document.getElementById('assumptions-note').textContent =
      'Assumes dividends paid annually at year end (real payers are usually quarterly), dividend per share growing ' + r.inputs.divGrowth +
      '%/yr from a ' + r.inputs.yield + '% starting yield, price growing ' + r.inputs.pxGrowth + '%/yr, reinvestment at year-end prices, and no taxes or fees. Starting share count normalized to a $100 share price.';
  }

  function renderCharts(r) {
    const labels = r.series.map(s => String(s.year));
    const dripData = r.series.map(s => Math.round(s.drip));
    const cashData = r.series.map(s => Math.round(s.cash));

    if (chart) chart.destroy();
    chart = new Chart(document.getElementById('chart'), {
      type: 'line',
      data: { labels, datasets: [
        {
          label: 'Dividends taken as cash',
          data: cashData,
          borderColor: SLATE, backgroundColor: 'transparent',
          fill: false, tension: 0.15, pointRadius: 0, borderWidth: r.inputs.reinvest ? 2 : 2.5
        },
        {
          label: 'Dividends reinvested',
          data: dripData,
          borderColor: AMBER, backgroundColor: 'rgba(201,164,92,0.18)',
          fill: '-1', tension: 0.15, pointRadius: 0, borderWidth: r.inputs.reinvest ? 2.5 : 2
        }
      ]},
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: items => 'Year ' + items[0].label,
              label: item => item.dataset.label + ': ' + fmt(item.parsed.y),
              afterBody: items => {
                const idx = items[0].dataIndex;
                return 'Reinvestment gap: ' + fmt(dripData[idx] - cashData[idx]);
              }
            }
          }
        },
        scales: {
          x: {
            title: { display: true, text: 'Year', color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            ticks: { maxTicksLimit: 11, color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            grid: { display: false }, border: { color: SEAM }
          },
          y: {
            ticks: { callback: v => '$' + (Math.abs(v) >= 1000000 ? (v/1000000).toFixed(1) + 'M' : Math.abs(v) >= 1000 ? Math.round(v/1000) + 'k' : v), color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            grid: { color: SEAM }, border: { color: SEAM }
          }
        }
      }
    });

    // Income-per-year bars (skip year 0)
    const yrs = r.series.slice(1);
    const step = Math.max(1, Math.ceil(yrs.length / 25));
    const sampled = yrs.filter((s, idx) => idx % step === 0 || s.year === r.inputs.years);
    if (incomeChart) incomeChart.destroy();
    incomeChart = new Chart(document.getElementById('income-chart'), {
      type: 'bar',
      data: {
        labels: sampled.map(s => String(s.year)),
        datasets: [
          { label: 'With reinvestment', data: sampled.map(s => Math.round(s.dripIncome)), backgroundColor: 'rgba(201,164,92,0.75)', borderWidth: 0 },
          { label: 'Without', data: sampled.map(s => Math.round(s.cashIncome)), backgroundColor: 'rgba(91,122,157,0.65)', borderWidth: 0 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: items => 'Year ' + items[0].label,
              label: item => item.dataset.label + ': ' + fmt(item.parsed.y)
            }
          }
        },
        scales: {
          x: {
            ticks: { maxTicksLimit: 13, color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            grid: { display: false }, border: { color: SEAM }
          },
          y: {
            ticks: { callback: v => '$' + (Math.abs(v) >= 1000 ? Math.round(v/1000) + 'k' : v), color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            grid: { color: SEAM }, border: { color: SEAM }
          }
        }
      }
    });
  }

  function update() {
    const r = computeSeries();
    document.getElementById('income-display').value = formatMoneyValue(Math.round(r.inputs.initial * r.inputs.yield / 100));
    document.getElementById('drip-value').textContent = fmt(r.dripValue);
    document.getElementById('cash-value').textContent = fmt(r.cashValue);
    document.getElementById('cash-collected').textContent = fmt(r.cashCollected);
    document.getElementById('income-mode').textContent = r.inputs.reinvest ? '(DRIP)' : '(cash)';
    document.getElementById('final-income').textContent = fmt(r.inputs.reinvest ? r.finalDripIncome : r.finalCashIncome);
    renderWarnings(r);
    renderAdvBar(r);
    renderCharts(r);
    renderSummaryTable(r);
    scheduleUrlUpdate();
  }

  // Wire inputs with the same input/blur clamp pattern as the other Phases calculators.
  [
    ['initial', LIMITS.initial, true],
    ['yield', LIMITS.yield, false],
    ['div-growth', LIMITS.divGrowth, false],
    ['px-growth', LIMITS.pxGrowth, false],
    ['years', LIMITS.years, false]
  ].forEach(([id, lim, isMoney]) => {
    const el = document.getElementById(id);
    el.addEventListener('input', () => {
      markValidity(el, parseFloat(el.value), lim.min, lim.max);
      update();
    });
    el.addEventListener('blur', () => {
      const corrected = clamp(parseFloat(el.value), lim.min, lim.max);
      el.value = isMoney ? formatMoneyValue(corrected) : corrected;
      el.classList.remove('invalid');
      update();
    });
  });
  document.getElementById('reinvest').addEventListener('change', update);

  document.getElementById('copy-link').addEventListener('click', () => {
    updateUrlSilently();
    const statusEl = document.getElementById('copy-status');
    navigator.clipboard.writeText(window.location.href).then(() => {
      statusEl.textContent = 'link copied';
      setTimeout(() => { statusEl.textContent = ''; }, 2200);
    }).catch(() => {
      statusEl.textContent = 'copy failed — select the URL bar';
      setTimeout(() => { statusEl.textContent = ''; }, 2800);
    });
  });

  (function hydrateFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const encoded = params.get('d');
    if (encoded) {
      const state = decodeState(encoded);
      if (state) applyState(state);
    }
  })();

  update();
})();
</script>
</body>
</html>
