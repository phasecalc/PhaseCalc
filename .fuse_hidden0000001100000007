<script>
(function(){
  // Shim parseFloat so every existing call site transparently tolerates
  // comma-grouped input ("100,000") without needing to touch each call site.
  function parseFloat(v) { return window.parseFloat(String(v).replace(/,/g, '')); }

  const AMBER = '#C9A45C';
  const SLATE = '#5B7A9D';
  const COPPER = '#B07A4E';
  const SEAM = '#24344A';
  const PARCHMENT_FAINT = '#948D79';

  const SIMS = 500;
  const SEED = 20260704;

  const LIMITS = {
    amount: { min: 10, max: 100000 },
    deployMonths: { min: 1, max: 120 },
    horizonYears: { min: 1, max: 40 },
    rate: { min: 0, max: 15 },
    vol: { min: 0, max: 40 }
  };

  let chart = null;

  function fmt(n) {
    const sign = n < 0 ? '-' : '';
    return sign + '$' + Math.round(Math.abs(n)).toLocaleString();
  }
  // Same as fmt() but without the leading $ — used to redisplay money input
  // fields themselves with thousands separators after the user leaves them.
  function formatMoneyValue(n) {
    if (isNaN(n)) return '';
    const sign = n < 0 ? '-' : '';
    return sign + Math.round(Math.abs(n)).toLocaleString();
  }
  function fmtShort(n) {
    const a = Math.abs(n);
    if (a >= 1000000) return '$' + (n / 1000000).toFixed(2) + 'M';
    if (a >= 1000) return '$' + Math.round(n / 1000) + 'k';
    return '$' + Math.round(n);
  }
  function clamp(val, min, max) {
    if (isNaN(val)) return min;
    return Math.min(max, Math.max(min, val));
  }
  function markValidity(el, value, min, max) {
    const bad = isNaN(value) || value < min || value > max;
    el.classList.toggle('invalid', bad);
  }
  function getInputs() {
    const deployMonths = Math.round(clamp(parseFloat(document.getElementById('deploy-months').value), LIMITS.deployMonths.min, LIMITS.deployMonths.max));
    let horizonYears = Math.round(clamp(parseFloat(document.getElementById('horizon-years').value), LIMITS.horizonYears.min, LIMITS.horizonYears.max));
    const horizonClamped = horizonYears * 12 < deployMonths;
    if (horizonClamped) horizonYears = Math.ceil(deployMonths / 12);
    return {
      amount: clamp(parseFloat(document.getElementById('amount').value), LIMITS.amount.min, LIMITS.amount.max),
      freq: parseInt(document.getElementById('freq').value, 10),
      deployMonths, horizonYears, horizonClamped,
      rate: clamp(parseFloat(document.getElementById('rate').value), LIMITS.rate.min, LIMITS.rate.max),
      vol: clamp(parseFloat(document.getElementById('vol').value), LIMITS.vol.min, LIMITS.vol.max),
      compareLS: document.getElementById('compare-ls').checked
    };
  }

  // --- Seeded PRNG (mulberry32) + Box-Muller, so results are reproducible ---
  function mulberry32(seed) {
    let a = seed >>> 0;
    return function() {
      a |= 0; a = (a + 0x6D2B79F5) | 0;
      let t = Math.imul(a ^ (a >>> 15), 1 | a);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }
  function makeGaussian(rand) {
    let spare = null;
    return function() {
      if (spare !== null) { const v = spare; spare = null; return v; }
      let u = 0, v = 0, s = 0;
      do {
        u = rand() * 2 - 1;
        v = rand() * 2 - 1;
        s = u * u + v * v;
      } while (s >= 1 || s === 0);
      const m = Math.sqrt(-2 * Math.log(s) / s);
      spare = v * m;
      return u * m;
    };
  }

  // --- Shareable link encode/decode (same pattern as the other Phases calculators) ---
  function encodeState() {
    const i = getInputs();
    const state = { a: i.amount, f: i.freq, dm: i.deployMonths, hy: i.horizonYears, r: i.rate, v: i.vol, l: i.compareLS ? 1 : 0 };
    const json = JSON.stringify(state);
    const b64 = btoa(unescape(encodeURIComponent(json)));
    return b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  }
  function decodeState(encoded) {
    try {
      const b64 = encoded.replace(/-/g, '+').replace(/_/g, '/');
      const json = decodeURIComponent(escape(atob(b64)));
      const state = JSON.parse(json);
      if (!state || typeof state.a === 'undefined') return null;
      return state;
    } catch (e) { return null; }
  }
  function applyState(s) {
    document.getElementById('amount').value = formatMoneyValue(clamp(s.a, LIMITS.amount.min, LIMITS.amount.max));
    if ([52, 12, 4].includes(parseInt(s.f, 10))) document.getElementById('freq').value = String(s.f);
    document.getElementById('deploy-months').value = clamp(s.dm, LIMITS.deployMonths.min, LIMITS.deployMonths.max);
    document.getElementById('horizon-years').value = clamp(s.hy, LIMITS.horizonYears.min, LIMITS.horizonYears.max);
    document.getElementById('rate').value = clamp(s.r, LIMITS.rate.min, LIMITS.rate.max);
    document.getElementById('vol').value = clamp(s.v, LIMITS.vol.min, LIMITS.vol.max);
    document.getElementById('compare-ls').checked = !!s.l;
  }
  function updateUrlSilently() {
    const url = new URL(window.location.href);
    url.searchParams.set('d', encodeState());
    window.history.replaceState(null, '', url.toString());
  }
  let urlUpdateTimer = null;
  function scheduleUrlUpdate() {
    clearTimeout(urlUpdateTimer);
    urlUpdateTimer = setTimeout(updateUrlSilently, 400);
  }

  function percentile(sortedArr, p) {
    const idx = (p / 100) * (sortedArr.length - 1);
    const lo = Math.floor(idx), hi = Math.ceil(idx);
    if (lo === hi) return sortedArr[lo];
    return sortedArr[lo] + (sortedArr[hi] - sortedArr[lo]) * (idx - lo);
  }

  function computeSeries() {
    const i = getInputs();
    // Deployment window: DCA only contributes during these steps. After it
    // ends, DCA simply holds and compounds — same as the lump sum has been
    // doing since day one — so the whole horizon shows whether an early
    // timing edge (or setback) persists, shrinks, or grows.
    const steps = i.horizonYears * i.freq;
    const deploySteps = Math.max(1, Math.min(steps, Math.round(i.deployMonths * i.freq / 12)));
    const total = i.amount * deploySteps;
    // Expected return is treated as the long-run CAGR: log-return drift per
    // step is ln(1+r)/freq, so the MEDIAN simulated path compounds at exactly
    // the stated rate. Volatility spreads outcomes around that median.
    const drift = Math.log(1 + i.rate / 100) / i.freq;
    const sigma = (i.vol / 100) / Math.sqrt(i.freq);

    // Sample ~100 points for the chart regardless of horizon, but always
    // include the exact step where deployment ends so the chart can mark it.
    const sampleEvery = Math.max(1, Math.ceil(steps / 100));
    const samplePoints = [];
    for (let s = sampleEvery; s <= steps; s += sampleEvery) samplePoints.push(s);
    if (samplePoints[samplePoints.length - 1] !== steps) samplePoints.push(steps);
    if (!samplePoints.includes(deploySteps)) {
      samplePoints.push(deploySteps);
      samplePoints.sort((a, b) => a - b);
    }

    // dcaAt[k][sim], lsAt[k][sim]
    const dcaAt = samplePoints.map(() => new Float64Array(SIMS));
    const lsAt = samplePoints.map(() => new Float64Array(SIMS));
    const rand = mulberry32(SEED);
    const gauss = makeGaussian(rand);

    let lsWins = 0;
    for (let sim = 0; sim < SIMS; sim++) {
      let dca = 0, ls = total;
      let k = 0;
      for (let m = 1; m <= steps; m++) {
        // Contribution lands at the start of the interval, then the interval's
        // return applies to everything. Once the deployment window ends, DCA
        // stops contributing and just compounds like the lump sum does.
        const growth = Math.exp(drift + sigma * gauss());
        if (m <= deploySteps) {
          dca = (dca + i.amount) * growth;
        } else {
          dca = dca * growth;
        }
        ls = ls * growth;
        if (samplePoints[k] === m) {
          dcaAt[k][sim] = dca;
          lsAt[k][sim] = ls;
          k++;
        }
      }
      if (ls > dca) lsWins++;
    }

    // Percentiles per sample point.
    const series = [{ t: 0, basis: 0, p10: 0, p50: 0, p90: 0, ls50: total }];
    samplePoints.forEach((m, k) => {
      const d = Array.from(dcaAt[k]).sort((a, b) => a - b);
      const l = Array.from(lsAt[k]).sort((a, b) => a - b);
      series.push({
        t: m / i.freq,
        basis: i.amount * Math.min(m, deploySteps),
        p10: percentile(d, 10),
        p50: percentile(d, 50),
        p90: percentile(d, 90),
        ls50: percentile(l, 50),
        ls10: percentile(l, 10)
      });
    });

    const deployEndYears = deploySteps / i.freq;
    const last = series[series.length - 1];
    return {
      deploySteps, deployEndYears,
      inputs: i, steps, total, series,
      dcaMedian: last.p50, dcaP10: last.p10, dcaP90: last.p90,
      lsMedian: last.ls50, lsP10: last.ls10,
      lsWinPct: (lsWins / SIMS) * 100
    };
  }

  function renderWarnings(r) {
    const el = document.getElementById('warnings');
    el.innerHTML = '';
    if (r.inputs.horizonClamped) {
      const div = document.createElement('div');
      div.className = 'warning';
      div.textContent = 'Total time horizon must be at least as long as the deployment period — using ' + r.inputs.horizonYears + ' year' + (r.inputs.horizonYears === 1 ? '' : 's') + '.';
      el.appendChild(div);
    }
    if (r.inputs.deployMonths > 24) {
      const div = document.createElement('div');
      div.className = 'info-note';
      div.textContent = 'A ' + r.inputs.deployMonths + '-month deployment window is longer than the realistic windfall-timing decision (6-12 months is the classic case). Stretching it out further isn’t really "DCA" anymore — it’s just slow, gradual saving, and it mechanically favors the lump sum more and more the longer it runs.';
      el.appendChild(div);
    }
    if (r.inputs.vol === 0) {
      const div = document.createElement('div');
      div.className = 'info-note';
      div.textContent = 'Volatility is 0 — this is the smooth flat-rate projection most calculators show. Real markets swing; try 15% to see the honest range of outcomes.';
      el.appendChild(div);
    }
    if (r.inputs.vol >= 25) {
      const div = document.createElement('div');
      div.className = 'info-note';
      div.textContent = r.inputs.vol + '% volatility is concentrated-portfolio territory (single sectors, small caps, crypto). Note how wide the 10th–90th percentile band gets — that spread is the real cost of concentration.';
      el.appendChild(div);
    }
  }

  function renderDuelBar(r) {
    const bar = document.getElementById('duel-bar');
    const cap = document.getElementById('duel-caption');
    bar.innerHTML = '';

    if (!r.inputs.compareLS) {
      bar.style.display = 'none';
      cap.textContent = '';
      return;
    }
    bar.style.display = 'flex';

    const maxV = Math.max(r.dcaMedian, r.lsMedian, 1);
    const d = document.createElement('div');
    d.className = 'duel-seg dca';
    d.style.height = Math.max(28, (r.dcaMedian / maxV) * 74) + 'px';
    d.textContent = 'DCA ' + fmtShort(r.dcaMedian);
    const l = document.createElement('div');
    l.className = 'duel-seg ls';
    l.style.height = Math.max(28, (r.lsMedian / maxV) * 74) + 'px';
    l.textContent = 'lump sum ' + fmtShort(r.lsMedian);
    bar.appendChild(d); bar.appendChild(l);

    const winner = r.lsWinPct >= 50 ? 'lump sum' : 'DCA';
    const winPct = Math.round(r.lsWinPct >= 50 ? r.lsWinPct : 100 - r.lsWinPct);
    cap.innerHTML = fmt(r.total) + ' deployed over ' + r.inputs.deployMonths + ' month' + (r.inputs.deployMonths === 1 ? '' : 's') + ' vs. day one, both held to year ' + r.inputs.horizonYears + ', same ' + SIMS + ' simulated markets: <span class="win">' + winner + ' ended higher ' + winPct + '% of the time</span> — but in the worst tenth of markets, DCA held ' + fmtShort(r.dcaP10) + ' vs ' + fmtShort(r.lsP10) + ' for the lump sum.';
  }

  function renderSummaryTable(r) {
    const el = document.getElementById('summary-table');
    const marks = [0.25, 0.5, 0.75, 1].map(f => Math.round(r.inputs.horizonYears * f)).filter((v, idx, a) => v >= 1 && a.indexOf(v) === idx);

    let html = '<table><tr><th>Year</th><th>Contributed</th><th>DCA median</th><th>10th pct</th><th>90th pct</th>' + (r.inputs.compareLS ? '<th>Lump-sum median</th>' : '') + '</tr>';
    marks.forEach(y => {
      // find nearest sample point at or before year y
      let pt = r.series[0];
      for (const s of r.series) { if (s.t <= y + 1e-9) pt = s; else break; }
      html += '<tr><td>' + y + (y === r.inputs.horizonYears ? ' — end' : (Math.abs(y - r.deployEndYears) < 0.5 ? ' — fully deployed' : '')) + '</td><td>' + fmt(pt.basis) + '</td>' +
        '<td class="hi">' + fmt(pt.p50) + '</td><td>' + fmt(pt.p10) + '</td><td>' + fmt(pt.p90) + '</td>' +
        (r.inputs.compareLS ? '<td>' + fmt(pt.ls50) + '</td>' : '') + '</tr>';
    });
    html += '</table>';
    el.innerHTML = html;

    const freqName = r.inputs.freq === 52 ? 'weekly' : r.inputs.freq === 12 ? 'monthly' : 'quarterly';
    document.getElementById('assumptions-note').textContent =
      'Assumes ' + fmt(r.inputs.amount) + ' invested ' + freqName + ' at the start of each interval for ' + r.inputs.deployMonths +
      ' months (' + fmt(r.total) + ' total), then held with no further contributions through year ' + r.inputs.horizonYears +
      '. Returns are log-normal with a ' + r.inputs.rate + '% long-run CAGR and ' + r.inputs.vol +
      '% annual volatility, across ' + SIMS + ' simulated markets with a fixed seed (reproducible). The lump-sum comparison invests the same total on day one into the same markets and holds it for the same horizon. No taxes, fees, or dividends modeled.';
  }

  function renderChart(r) {
    const ctx = document.getElementById('chart');
    const labels = r.series.map(s => s.t.toFixed(1));
    const basisData = r.series.map(s => Math.round(s.basis));
    const p50Data = r.series.map(s => Math.round(s.p50));
    const p10Data = r.series.map(s => Math.round(s.p10));
    const p90Data = r.series.map(s => Math.round(s.p90));
    const lsData = r.series.map(s => Math.round(s.ls50));

    const datasets = [
      {
        label: 'Cost basis (money in)',
        data: basisData,
        borderColor: PARCHMENT_FAINT, backgroundColor: 'transparent',
        fill: false, stepped: true, pointRadius: 0, borderWidth: 1.5
      },
      {
        label: 'DCA median value',
        data: p50Data,
        borderColor: AMBER, backgroundColor: 'transparent',
        fill: false, tension: 0.15, pointRadius: 0, borderWidth: 2
      },
      {
        label: '90th percentile',
        data: p90Data,
        borderColor: 'rgba(201,164,92,0.0)', backgroundColor: 'rgba(201,164,92,0.14)',
        fill: '+1', tension: 0.15, pointRadius: 0, borderWidth: 0, isBand: true
      },
      {
        label: '10th percentile',
        data: p10Data,
        borderColor: 'rgba(201,164,92,0.0)', backgroundColor: 'transparent',
        fill: false, tension: 0.15, pointRadius: 0, borderWidth: 0, isBand: true
      }
    ];
    if (r.inputs.compareLS) {
      datasets.push({
        label: 'Lump-sum median value',
        data: lsData,
        borderColor: SLATE, backgroundColor: 'transparent',
        fill: false, tension: 0.15, pointRadius: 0, borderWidth: 2, borderDash: [5, 4]
      });
    }

    const deployIdx = r.series.findIndex(s => Math.abs(s.t - r.deployEndYears) < 1e-6);

    if (chart) chart.destroy();
    chart = new Chart(ctx, {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            filter: item => !item.dataset.isBand,
            callbacks: {
              title: items => 'Year ' + items[0].label,
              label: item => item.dataset.label + ': ' + fmt(item.parsed.y),
              afterBody: items => {
                const idx = items[0].dataIndex;
                return '10th–90th pct: ' + fmtShort(p10Data[idx]) + ' – ' + fmtShort(p90Data[idx]);
              }
            }
          }
        },
        scales: {
          x: {
            title: { display: true, text: 'Years', color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            ticks: { maxTicksLimit: 11, color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 },
              callback: function(v) { const n = parseFloat(this.getLabelForValue(v)); return Number.isInteger(n) ? n : n.toFixed(1); } },
            grid: { display: false }, border: { color: SEAM }
          },
          y: {
            ticks: { callback: v => '$' + (Math.abs(v) >= 1000000 ? (v/1000000).toFixed(1) + 'M' : Math.abs(v) >= 1000 ? Math.round(v/1000) + 'k' : v), color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            grid: { color: SEAM }, border: { color: SEAM }
          }
        }
      },
      plugins: [{
        id: 'deployEndLine',
        afterDraw(c) {
          if (deployIdx < 0) return;
          const { ctx, chartArea, scales } = c;
          const x = scales.x.getPixelForValue(deployIdx);
          if (x < chartArea.left || x > chartArea.right) return;
          ctx.save();
          ctx.strokeStyle = COPPER;
          ctx.lineWidth = 1.5;
          ctx.setLineDash([4, 3]);
          ctx.beginPath(); ctx.moveTo(x, chartArea.top); ctx.lineTo(x, chartArea.bottom); ctx.stroke();
          ctx.setLineDash([]);
          ctx.fillStyle = COPPER;
          ctx.beginPath(); ctx.arc(x, chartArea.top + 6, 3, 0, Math.PI * 2); ctx.fill();
          ctx.restore();
        }
      }]
    });
  }

  function update() {
    const r = computeSeries();
    document.getElementById('total-display').value = formatMoneyValue(r.total);
    document.getElementById('total-contrib').textContent = fmt(r.total);
    document.getElementById('dca-median').textContent = fmt(r.dcaMedian);
    document.getElementById('dca-range').textContent = fmtShort(r.dcaP10) + ' – ' + fmtShort(r.dcaP90);
    document.getElementById('ls-median').textContent = r.inputs.compareLS ? fmt(r.lsMedian) : '—';
    document.getElementById('legend-ls').style.display = r.inputs.compareLS ? '' : 'none';
    renderWarnings(r);
    renderDuelBar(r);
    renderChart(r);
    renderSummaryTable(r);
    scheduleUrlUpdate();
  }

  // Wire inputs with the same input/blur clamp pattern as the other Phases calculators.
  [
    ['amount', LIMITS.amount, true],
    ['deploy-months', LIMITS.deployMonths, false],
    ['horizon-years', LIMITS.horizonYears, false],
    ['rate', LIMITS.rate, false],
    ['vol', LIMITS.vol, false]
  ].forEach(([id, lim, isMoney]) => {
    const el = document.getElementById(id);
    el.addEventListener('input', () => {
      markValidity(el, parseFloat(el.value), lim.min, lim.max);
      update();
    });
    el.addEventListener('blur', () => {
      const corrected = clamp(parseFloat(el.value), lim.min, lim.max);
      el.value = isMoney ? formatMoneyValue(corrected) : corrected;
      el.classList.remove('invalid');
      update();
    });
  });
  document.getElementById('freq').addEventListener('change', update);
  document.getElementById('compare-ls').addEventListener('change', update);

  document.getElementById('copy-link').addEventListener('click', () => {
    updateUrlSilently();
    const statusEl = document.getElementById('copy-status');
    navigator.clipboard.writeText(window.location.href).then(() => {
      statusEl.textContent = 'link copied';
      setTimeout(() => { statusEl.textContent = ''; }, 2200);
    }).catch(() => {
      statusEl.textContent = 'copy failed — select the URL bar';
      setTimeout(() => { statusEl.textContent = ''; }, 2800);
    });
  });

  (function hydrateFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const encoded = params.get('d');
    if (encoded) {
      const state = decodeState(encoded);
      if (state) applyState(state);
    }
  })();

  update();
})();
</script>
</body>
</html>
