<script>
(function(){
  // Shim parseFloat so every existing call site transparently tolerates
  // comma-grouped input ("100,000") without needing to touch each call site.
  function parseFloat(v) { return window.parseFloat(String(v).replace(/,/g, '')); }

  const AMBER = '#C9A45C';
  const SLATE = '#5B7A9D';
  const COPPER = '#B07A4E';
  const SEAM = '#24344A';
  const PARCHMENT_FAINT = '#948D79';
  const WARN = '#C46552';

  const LIMITS = {
    balance: { min: 1000, max: 10000000 },
    rate: { min: 0.1, max: 25 },
    years: { min: 0.25, max: 30 },
    expret: { min: -20, max: 25 }
  };

  let chart = null;

  function fmt(n) {
    const sign = n < 0 ? '-' : '';
    return sign + '$' + Math.round(Math.abs(n)).toLocaleString();
  }
  // Same as fmt() but without the leading $ — used to redisplay money input
  // fields themselves with thousands separators after the user leaves them.
  function formatMoneyValue(n) {
    if (isNaN(n)) return '';
    const sign = n < 0 ? '-' : '';
    return sign + Math.round(Math.abs(n)).toLocaleString();
  }
  function fmtShort(n) {
    const a = Math.abs(n);
    const sign = n < 0 ? '-' : '';
    if (a >= 1000000) return sign + '$' + (a / 1000000).toFixed(2) + 'M';
    if (a >= 1000) return sign + '$' + Math.round(a / 1000) + 'k';
    return sign + '$' + Math.round(a);
  }
  function clamp(val, min, max) {
    if (isNaN(val)) return min;
    return Math.min(max, Math.max(min, val));
  }
  function markValidity(el, value, min, max) {
    const bad = isNaN(value) || value < min || value > max;
    el.classList.toggle('invalid', bad);
  }
  function getInputs() {
    return {
      balance: clamp(parseFloat(document.getElementById('balance').value), LIMITS.balance.min, LIMITS.balance.max),
      rate: clamp(parseFloat(document.getElementById('rate').value), LIMITS.rate.min, LIMITS.rate.max),
      years: clamp(parseFloat(document.getElementById('years').value), LIMITS.years.min, LIMITS.years.max),
      expret: clamp(parseFloat(document.getElementById('expret').value), LIMITS.expret.min, LIMITS.expret.max),
      compareRet: document.getElementById('compare-ret').checked
    };
  }

  // --- Shareable link encode/decode (same pattern as the other Phases calculators) ---
  function encodeState() {
    const i = getInputs();
    const state = { b: i.balance, r: i.rate, y: i.years, e: i.expret, c: i.compareRet ? 1 : 0 };
    const json = JSON.stringify(state);
    const b64 = btoa(unescape(encodeURIComponent(json)));
    return b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  }
  function decodeState(encoded) {
    try {
      const b64 = encoded.replace(/-/g, '+').replace(/_/g, '/');
      const json = decodeURIComponent(escape(atob(b64)));
      const state = JSON.parse(json);
      if (!state || typeof state.b === 'undefined') return null;
      return state;
    } catch (e) { return null; }
  }
  function applyState(s) {
    document.getElementById('balance').value = formatMoneyValue(clamp(s.b, LIMITS.balance.min, LIMITS.balance.max));
    document.getElementById('rate').value = clamp(s.r, LIMITS.rate.min, LIMITS.rate.max);
    document.getElementById('years').value = clamp(s.y, LIMITS.years.min, LIMITS.years.max);
    document.getElementById('expret').value = clamp(s.e, LIMITS.expret.min, LIMITS.expret.max);
    document.getElementById('compare-ret').checked = !!s.c;
  }
  function updateUrlSilently() {
    const url = new URL(window.location.href);
    url.searchParams.set('d', encodeState());
    window.history.replaceState(null, '', url.toString());
  }
  let urlUpdateTimer = null;
  function scheduleUrlUpdate() {
    clearTimeout(urlUpdateTimer);
    urlUpdateTimer = setTimeout(updateUrlSilently, 400);
  }

  // --- Core math ---
  // Interest accrues to the loan and compounds monthly (the broker posts it to
  // your account; unpaid, it grows the balance).
  function compute() {
    const i = getInputs();
    const months = Math.round(i.years * 12);
    const yrs = months / 12; // use the rounded horizon consistently
    const mRate = i.rate / 100 / 12;

    const growthFactor = Math.pow(1 + mRate, months);
    const totalOwed = i.balance * growthFactor;
    const totalInterest = totalOwed - i.balance;

    // Break-even annual return = the loan's effective annual rate (APY).
    // (1 + be)^y = (1 + r/12)^(12y)  =>  be = (1 + r/12)^12 - 1, for any y.
    const breakEven = Math.pow(1 + mRate, 12) - 1;

    // Gain on the borrowed dollars at the user's expected flat return.
    const gainAtExp = i.balance * (Math.pow(1 + i.expret / 100, yrs) - 1);
    const net = gainAtExp - totalInterest;

    return { inputs: i, months, yrs, totalOwed, totalInterest, breakEven, gainAtExp, net };
  }

  function gainAt(balance, retPct, yrs) {
    return balance * (Math.pow(1 + retPct / 100, yrs) - 1);
  }

  function renderWarnings(r) {
    const el = document.getElementById('warnings');
    el.innerHTML = '';
    const i = r.inputs;

    if (i.rate >= 9) {
      const div = document.createElement('div');
      div.className = 'warning';
      div.textContent = i.rate.toFixed(1) + '% is full-service-broker territory. Tiered brokers charge roughly benchmark +1.5% under $100k (~5.1% as of mid-2026). At this rate your break-even is ' + (r.breakEven * 100).toFixed(1) + '%/yr — above the long-run average return of most diversified portfolios.';
      el.appendChild(div);
    }
    if (i.compareRet && i.expret / 100 <= r.breakEven) {
      const div = document.createElement('div');
      div.className = 'warning';
      div.textContent = 'Your expected return (' + i.expret + '%) does not clear the ' + (r.breakEven * 100).toFixed(2) + '% break-even. Even if markets behave exactly as you expect, this leverage loses ' + fmt(-r.net) + ' over the period.';
      el.appendChild(div);
    }
    if (i.compareRet && i.expret >= 12) {
      const div = document.createElement('div');
      div.className = 'info-note';
      div.textContent = i.expret + '%/yr is an aggressive assumption — long-run diversified-equity averages sit near 7–10% before inflation, and leverage amplifies the years that miss. Consider re-running at 7%.';
      el.appendChild(div);
    }
    if (r.yrs >= 5) {
      const div = document.createElement('div');
      div.className = 'info-note';
      div.textContent = 'Over ' + r.yrs.toFixed(r.yrs % 1 ? 2 : 0) + ' years, accrued interest grows the loan ' + ((r.totalOwed / r.inputs.balance - 1) * 100).toFixed(0) + '% — and a growing loan shrinks your equity cushion, moving the margin-call trigger closer even in a flat market. Rates also float; a long hold is a bet on rates too.';
      el.appendChild(div);
    }
  }

  function renderDuelBar(r) {
    const bar = document.getElementById('duel-bar');
    const cap = document.getElementById('duel-caption');
    bar.innerHTML = '';

    if (!r.inputs.compareRet) {
      bar.style.display = 'none';
      cap.textContent = '';
      return;
    }
    bar.style.display = 'flex';

    const gain = Math.max(0, r.gainAtExp);
    const maxV = Math.max(gain, r.totalInterest, 1);
    const g = document.createElement('div');
    g.className = 'duel-seg gain';
    g.style.height = Math.max(28, (gain / maxV) * 74) + 'px';
    g.textContent = 'borrowed $ earn ' + fmtShort(r.gainAtExp);
    const c = document.createElement('div');
    c.className = 'duel-seg cost';
    c.style.height = Math.max(28, (r.totalInterest / maxV) * 74) + 'px';
    c.textContent = 'interest costs ' + fmtShort(r.totalInterest);
    bar.appendChild(g); bar.appendChild(c);

    const verdict = r.net >= 0
      ? 'leverage nets +' + fmt(r.net).replace('$', '$')
      : 'leverage loses ' + fmt(r.net);
    cap.innerHTML = 'At a flat ' + r.inputs.expret + '%/yr on ' + fmt(r.inputs.balance) + ' borrowed for ' + r.yrs.toFixed(r.yrs % 1 ? 2 : 0) + ' years: <span class="win">' + verdict + '</span> — and a flat return is the optimistic case; real paths add volatility drag and margin-call risk.';
  }

  function renderSummaryTable(r) {
    const el = document.getElementById('summary-table');
    const i = r.inputs;
    const fracs = [0.25, 0.5, 0.75, 1];
    const seen = new Set();
    let html = '<table><tr><th>Time</th><th>Loan + accrued interest</th><th>Interest so far</th><th>Break-even growth needed</th>' + (i.compareRet ? '<th>Net at ' + i.expret + '%/yr</th>' : '') + '</tr>';
    fracs.forEach(f => {
      const m = Math.max(1, Math.round(r.months * f));
      if (seen.has(m)) return;
      seen.add(m);
      const y = m / 12;
      const owed = i.balance * Math.pow(1 + i.rate / 100 / 12, m);
      const interest = owed - i.balance;
      const label = y >= 1 ? (Number.isInteger(y) ? y + ' yr' : y.toFixed(2) + ' yr') : m + ' mo';
      const net = gainAt(i.balance, i.expret, y) - interest;
      html += '<tr><td>' + label + (m === r.months ? ' — end' : '') + '</td>' +
        '<td class="hi">' + fmt(owed) + '</td>' +
        '<td>' + fmt(interest) + '</td>' +
        '<td>' + fmt(interest + i.balance) + ' (' + ((Math.pow(owed / i.balance, 1 / Math.max(y, 1e-9)) - 1) * 100).toFixed(2) + '%/yr)</td>' +
        (i.compareRet ? '<td>' + fmt(net) + '</td>' : '') + '</tr>';
    });
    html += '</table>';
    el.innerHTML = html;

    document.getElementById('assumptions-note').textContent =
      'Assumes ' + fmt(i.balance) + ' borrowed at a fixed ' + i.rate + '% annual rate, accrued and compounded monthly with no paydowns, over ' + r.yrs.toFixed(r.yrs % 1 ? 2 : 0) + ' years. Break-even = the rate\'s APY: ' + (r.breakEven * 100).toFixed(2) + '%/yr, independent of balance and duration. Real margin rates float with policy rates. No taxes, fees, dividends, or margin-call effects modeled.';
  }

  function renderChart(r) {
    const ctx = document.getElementById('chart');
    const i = r.inputs;
    const bePct = r.breakEven * 100;

    const xMin = -15;
    const xMax = Math.max(20, Math.ceil(bePct) + 5, i.compareRet ? Math.ceil(i.expret) + 3 : 0);
    const N = 90;
    const step = (xMax - xMin) / N;

    const gainData = [], costData = [];
    for (let k = 0; k <= N; k++) {
      const x = xMin + k * step;
      gainData.push({ x: x, y: gainAt(i.balance, x, r.yrs) });
      costData.push({ x: x, y: r.totalInterest });
    }

    const datasets = [
      {
        label: 'What the borrowed dollars earn',
        data: gainData,
        borderColor: AMBER,
        backgroundColor: 'transparent',
        fill: { target: 1, above: 'rgba(201,164,92,0.16)', below: 'rgba(196,101,82,0.16)' },
        tension: 0, pointRadius: 0, borderWidth: 2, order: 2
      },
      {
        label: 'Margin interest cost',
        data: costData,
        borderColor: COPPER,
        backgroundColor: 'transparent',
        fill: false, tension: 0, pointRadius: 0, borderWidth: 1.5, borderDash: [5, 4], order: 3
      },
      {
        label: 'Break-even (' + bePct.toFixed(2) + '%/yr)',
        data: [{ x: bePct, y: r.totalInterest }],
        type: 'scatter',
        pointRadius: 4.5, pointHoverRadius: 6,
        pointBackgroundColor: SLATE, pointBorderColor: SLATE,
        order: 1
      }
    ];
    if (i.compareRet) {
      datasets.push({
        label: 'Your expected return (' + i.expret + '%/yr)',
        data: [{ x: i.expret, y: gainAt(i.balance, i.expret, r.yrs) }],
        type: 'scatter',
        pointRadius: 4.5, pointHoverRadius: 6, pointStyle: 'rectRot',
        pointBackgroundColor: r.net >= 0 ? AMBER : WARN,
        pointBorderColor: r.net >= 0 ? AMBER : WARN,
        order: 0
      });
    }

    if (chart) chart.destroy();
    chart = new Chart(ctx, {
      type: 'line',
      data: { datasets },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'nearest', axis: 'x', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: items => 'If the portfolio returns ' + items[0].parsed.x.toFixed(1) + '%/yr',
              label: item => {
                if (item.dataset.type === 'scatter') return item.dataset.label;
                return item.dataset.label + ': ' + fmt(item.parsed.y);
              },
              afterBody: items => {
                const x = items[0].parsed.x;
                const net = gainAt(i.balance, x, r.yrs) - r.totalInterest;
                return 'Net from leverage: ' + (net >= 0 ? '+' : '') + fmt(net);
              }
            }
          }
        },
        scales: {
          x: {
            type: 'linear', min: xMin, max: xMax,
            title: { display: true, text: 'Assumed annual portfolio return (%)', color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            ticks: { maxTicksLimit: 12, color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 }, callback: v => v + '%' },
            grid: { display: false }, border: { color: SEAM }
          },
          y: {
            title: { display: true, text: 'Dollars over the period', color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            ticks: { callback: v => (Math.abs(v) >= 1000000 ? (v < 0 ? '-' : '') + '$' + Math.abs(v / 1000000).toFixed(1) + 'M' : Math.abs(v) >= 1000 ? (v < 0 ? '-' : '') + '$' + Math.round(Math.abs(v) / 1000) + 'k' : '$' + v), color: PARCHMENT_FAINT, font: { family: 'IBM Plex Mono', size: 10 } },
            grid: { color: SEAM }, border: { color: SEAM }
          }
        }
      }
    });
  }

  function update() {
    const r = compute();
    document.getElementById('apy-display').value = (r.breakEven * 100).toFixed(2);
    document.getElementById('monthly-display').value = formatMoneyValue(Math.round(r.inputs.balance * r.inputs.rate / 100 / 12));
    document.getElementById('total-interest').textContent = fmt(r.totalInterest);
    document.getElementById('total-owed').textContent = fmt(r.totalOwed);
    document.getElementById('break-even').textContent = (r.breakEven * 100).toFixed(2) + '%/yr';

    const netEl = document.getElementById('net-outcome');
    if (r.inputs.compareRet) {
      netEl.textContent = (r.net >= 0 ? '+' : '') + fmt(r.net);
      netEl.className = 'value ' + (r.net >= 0 ? 'net-pos' : 'net-neg');
    } else {
      netEl.textContent = '—';
      netEl.className = 'value';
    }

    renderWarnings(r);
    renderDuelBar(r);
    renderChart(r);
    renderSummaryTable(r);
    scheduleUrlUpdate();
  }

  // Wire inputs with the same input/blur clamp pattern as the other Phases calculators.
  [
    ['balance', LIMITS.balance, true],
    ['rate', LIMITS.rate, false],
    ['years', LIMITS.years, false],
    ['expret', LIMITS.expret, false]
  ].forEach(([id, lim, isMoney]) => {
    const el = document.getElementById(id);
    el.addEventListener('input', () => {
      markValidity(el, parseFloat(el.value), lim.min, lim.max);
      update();
    });
    el.addEventListener('blur', () => {
      const corrected = clamp(parseFloat(el.value), lim.min, lim.max);
      el.value = isMoney ? formatMoneyValue(corrected) : corrected;
      el.classList.remove('invalid');
      update();
    });
  });
  document.getElementById('compare-ret').addEventListener('change', update);

  document.getElementById('copy-link').addEventListener('click', () => {
    updateUrlSilently();
    const statusEl = document.getElementById('copy-status');
    navigator.clipboard.writeText(window.location.href).then(() => {
      statusEl.textContent = 'link copied';
      setTimeout(() => { statusEl.textContent = ''; }, 2200);
    }).catch(() => {
      statusEl.textContent = 'copy failed — select the URL bar';
      setTimeout(() => { statusEl.textContent = ''; }, 2800);
    });
  });

  (function hydrateFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const encoded = params.get('d');
    if (encoded) {
      const state = decodeState(encoded);
      if (state) applyState(state);
    }
  })();

  update();
})();
</script>
</body>
</html>
